     <property name="styleSheet">
      <string notr="true">/* Header ka main background */
#headerWidget {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
}

/* Left side ke normal buttons (Overview, Inventory) */
#btnOverview, #btnInventory {
    color: #64748B;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: 600;
    font-size: 14px;
    border: none;
    background: transparent;
    padding: 8px 12px;
}

/* &quot;Reports&quot; wala Active button (Blue line ke sath) */
#btnReports {
    color: #1558A8;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: bold;
    font-size: 14px;
    border: none;
    background: transparent;
    border-bottom: 3px solid #1558A8; /* Neechay wali blue line */
    padding: 8px 12px;
}

/* Gol (Pill-shaped) Search Bar */
#searchAnalytics {
background-color: #F8FAFC;
    color: #333333;

    border: 1px solid #E2E8F0;
    border-radius: 18px; /* Is se search bar gol (round) ho jayega */
    padding: 8px 15px;
    color: #475569;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    min-width: 200px;
}

/* Sync Data Button */
#btnSyncData {
    background-color: #1558A8;
    color: #FFFFFF;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: bold;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Notification aur Profile ke Gol Buttons */
#btnBell, #btnProfile {
    background-color: transparent;
    border: 1px solid #E2E8F0;
    border-radius: 18px; /* Mukammal gol */
    min-width: 36px;
    min-height: 36px;
    color: #475569;
}</string>
