     <property name="styleSheet">
      <string notr="true">/* =========================================================================
   ROW 4: MAIN WHITE CONTAINER CARD
========================================================================= */
QFrame#row4Frame {
    background-color: #FFFFFF !important;
    border-radius: 12px !important;
    border: 1px solid #E2E8F0 !important;
    margin-top: 15px !important; /* Row 3 wale mini cards se gap */
    padding: 15px !important;
}

/* Title ka jo andar wala container dabba hai */
QFrame#tableHeaderContainer {
    background: transparent !important;
    border: none !important;
    background-color: transparent !important;
    margin-bottom: 5px !important;
}

/* =========================================================================
   ROW 4: TITLE STYLING (lblNutritionTitle)
========================================================================= */
QLabel#lblNutritionTitle {
    color: #0F172A !important;          /* Dark Blue/Black */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: 800 !important;        /* Extra Bold */
    font-size: 16px !important;
    border: none !important;
    background: transparent !important;
}

/* =========================================================================
   ROW 4: THE MASTER TABLE WIDGET STYLING (TableWidget)
========================================================================= */

/* 1. Main Table Body &amp; Static Items Text Color Fix */
QTableWidget#TableWidget,
QTableWidget#TableWidget QTableWidgetItem,
QTableWidget#TableWidget QModelIndex,
QTableWidget#TableWidget * {
    background-color: #FFFFFF !important;
    border: none !important;
    gridline-color: transparent !important; /* Horizonal/Vertical grid lines gayab */
    color: #475569 !important;               /* Clean Dark Grey Text */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-size: 13px !important;
}

/* 2. Top Columns/Headings (METRIC, AVERAGE VALUE, etc.) */
QTableWidget#TableWidget QHeaderView::section {
    background-color: #FFFFFF !important;
    color: #8C98A4 !important;              /* Headings text color */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important;
    font-size: 11px !important;
    padding: 12px 10px !important;
    border: none !important;
    border-bottom: 2px solid #F1F5F9 !important; /* Headings ke neechay professional line */
    text-align: left !important;
    text-transform: uppercase !important;   /* Automatic CAPITAL letters */
}

/* 3. Left Side numbers (1, 2, 3...) ko permanently hide karne ke liye */
QTableWidget#TableWidget QHeaderView::section:vertical {
    border: none !important;
    background-color: transparent !important;
    color: transparent !important;
    width: 0px !important;
}

/* 4. Table Rows / Cells Inside padding &amp; bottom border */
QTableWidget#TableWidget::item {
    color: #475569 !important;
    padding: 12px 10px !important;          /* Text spacing */
    border-bottom: 1px solid #F1F5F9 !important; /* Rows ke darmayan divider line */
}

/* 5. Clicked / Selected Rows Appearance */
QTableWidget#TableWidget::item:focus, 
QTableWidget#TableWidget::item:selected {
    background-color: #F8FAFC !important;   /* Light grey elegant hover/select affect */
    color: #0F172A !important;
    outline: none !important;
}</string>
