     <property name="styleSheet">
      <string notr="true">/* --- ANALYTICS TITLE &amp; SUBTITLE --- */
#lblAnalyticsTitle {
    font-size: 22px;
    font-weight: 900;
    color: #0F172A;
}

#lblAnalyticsSubtitle {
    font-size: 13px;
    color: #64748B;
    margin-top: 2px;
}

/* --- DAYS FILTER BUTTONS --- */
#btn7Days {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    color: #475569;
    font-weight: bold;
    font-size: 13px;
    padding: 6px 16px;
}

#btn7Days:hover{
    background-color: #F8FAFC;
    border: 1px solid #CBD5E1;
}

/* Active Button (30 Days - Blue) */
#btn30Days {
    background-color: #1558A8;
    border: 1px solid #1558A8;
    border-radius: 6px;
    color: #FFFFFF;
    font-weight: bold;
    font-size: 13px;
    padding: 6px 16px;
}</string>
