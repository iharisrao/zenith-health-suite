     <property name="styleSheet">
      <string notr="true">QLabel#lblIntensitySub {
    color: #0F172A !important;
   font-family:   Arial !important;
    font-weight: 800 !important;
    font-size: 11px !important;
    border: none !important;
    background: transparent !important;
}
QLabel#lblIntensityTitle {
    color: #0F172A !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: 800 !important;
    font-size: 16px !important;
    border: none !important;
    background: transparent !important;
}
/* =========================================
   MINI CARDS: TITLES (Oopar wala chota text)
========================================= */
#lblBPTitle, #lblHydrationTitle, #lblStressTitle, #lblCaloriesTitle {
    color: #64748B !important;          /* Grey color */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: 700 !important;        /* Bold */
    font-size: 11px !important;
    letter-spacing: 1px !important;
    background: transparent !important;
    border: none !important;
}

/* =========================================
   MINI CARDS: VALUES (Beech wale baray numbers)
========================================= */
#lblBPValue, #lblHydrationValue, #lblStressValue, #lblCaloriesValue {
    color: #0F172A !important;          /* Dark Blue/Black color */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: 900 !important;        /* Extra Bold */
    font-size: 26px !important;         /* Bada Size */
    background: transparent !important;
    border: none !important;
}

/* =========================================
   MINI CARDS: SUBTITLES (Neechay wala halka text)
========================================= */
#lblBPSub, #lblHydrationSub, #lblStressSub, #lblCaloriesSub {
    color: #8C98A4 !important;          /* Light Grey color */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: normal !important;
    font-size: 12px !important;
    background: transparent !important;
    border: none !important;
}</string>
