  <property name="styleSheet">
   <string notr="true">#centralwidget { background-color: #F4F7FA; }
QFrame { background-color: #FFFFFF; border-radius: 12px; border: none; }
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox { background-color: #F8FAFC; border: none; border-bottom: 2px solid #E2E8F0; border-radius: 4px 4px 0px 0px; padding: 10px 15px; color: #0F172A; font-weight: bold; font-size: 14px; }
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus { background-color: #F0F7FF; border-bottom: 2px solid #1558A8; }
QSpinBox::up-button, QSpinBox::down-button, QDoubleSpinBox::up-button, QDoubleSpinBox::down-button { width: 0px; border: none; background: transparent; }
QComboBox { font-weight: normal; }
QComboBox::drop-down { subcontrol-origin: padding; subcontrol-position: top right; width: 35px; border: none; }
QComboBox::down-arrow { image: url(&quot;data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAoAAAAKCAYAAACNMs+9AAAAXklEQVQYV2NkIBIwEqmOgXz4//9/BkYGBgYWBgYGGzxmMAI1MTEwMDCwMjAweOBWBCNAGmDymGACuBXBCJBmkDwmGOZ/BkYGLIphCrBpxGYYpmOIQvL/fxB78SlEBgB9rBl32XhFhAAAAABJRU5ErkJggg==&quot;); width: 14px; height: 14px; }
QComboBox::down-arrow:on { top: 1px; left: 1px; }
QComboBox QAbstractItemView { font-weight: normal; background-color: #FFFFFF; selection-background-color: #F0F7FF; selection-color: #1558A8; border: 1px solid #E2E8F0; border-radius: 4px; outline: 0px; }
QTabWidget::pane { border: none; background: transparent; }
QTabWidget::tab-bar { alignment: center; }
QTabBar { background-color: #E2E8F0; border-radius: 20px; }
QTabBar::tab { background-color: transparent; color: #64748B; padding: 8px 30px; border-radius: 15px; margin: 4px; font-weight: bold; font-size: 13px; }
QTabBar::tab:selected { background-color: #FFFFFF; color: #1558A8; border: none; }
QLabel { color: #475569; font-weight: bold; background: transparent; border: none; }
QPushButton { background-color: #1558A8; color: white; border-radius: 8px; padding: 12px; font-weight: bold; font-size: 14px; border: none; }
QPushButton:hover { background-color: #0E417F; }

#sidebarWidget {
    background-color: #FFFFFF;
    border-right: 1px solid #E5E7EB;
    min-width: 260px; 
}

#appNameLabel {
    color: #1558A8;
    font-size: 18px;
    font-weight: 800;
    padding: 5px 15px 0px 15px;
    background-color: transparent;
    margin-top: 0px;
    border: none;
    min-height: 30px;
    max-height: 35px;
}

#sidebarWidget QPushButton {
    text-align: left;
    padding: 8px 20px;
    background-color: transparent;
    border: none;
    color: #6B7280; 
    font-size: 14px;
    font-weight: 600;
    margin: 2px 15px; 
    border-radius: 8px;
    min-height: 34px; 
}

#sidebarWidget QPushButton:hover {
    background-color: #F0F7FF; 
    color: #1558A8;            
}

QPushButton#activityButton {
    background-color: #F0F7FF !important;
    color: #1558A8 !important;
    font-weight: 900 !important;
    border-left: 4px solid #1558A8 !important;
    border-radius: 0px 8px 8px 0px !important;
}


#headerWidget { background: transparent; border-bottom: 1px solid #E2E8F0; }
QLabel#lblHeaderTitle { color: #0F172A; font-size: 22px; font-weight: 900; }
QPushButton#btnHeaderDate { background-color: #FFFFFF; color: #475569; border: 1px solid #E2E8F0; border-radius: 16px; padding: 6px 20px; font-weight: bold; }
QPushButton#btnNotification, QPushButton#btnUserProfile { background-color: #FFFFFF; color: #475569; border: 1px solid #E2E8F0; border-radius: 18px; min-width: 36px; max-width: 36px; min-height: 36px; max-height: 36px; qproperty-iconSize: 18px 18px; }
QPushButton#btnHeaderDate:hover, QPushButton#btnNotification:hover, QPushButton#btnUserProfile:hover { background-color: #F8FAFC; border: 1px solid #CBD5E1; }
QLabel#lblLogActivity, QLabel#lblLogVitals, QLabel#lblLogNutrition { color: #0F172A; font-size: 16px; font-weight: 900; background: transparent; border: none; padding-bottom: 10px; }
QFrame#vitalsRefCard { background-color: #F8FAFC; border-radius: 12px; border: 1px solid #E2E8F0; }
QLabel#lblClinicalTitle { color: #1558A8; font-size: 13px; font-weight: 900; letter-spacing: 1px; padding-bottom: 8px; }
QFrame#lineClinical { border: none; background-color: #CBD5E1; max-height: 2px; }</string>
