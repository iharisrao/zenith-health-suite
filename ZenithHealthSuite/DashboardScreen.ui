  <property name="styleSheet">
   <string notr="true">#centralwidget {
    background-color: #F4F7FA;
}

#headerWidget {
    background-color: transparent;
    border-bottom: none;
}

#sidebarWidget {
    background-color: #FFFFFF;
    border-right: 1px solid #E5E7EB;
    min-width: 260px; 
}

#appNameLabel {
    color: #1558A8;
    font-size: 18px;
    font-weight: 800;
    padding: 5px 15px 0px 15px;
    background-color: transparent;
    margin-top: 0px;
    border: none;
    min-height: 30px;
    max-height: 35px;
}

#sidebarWidget QPushButton {
    text-align: left;
    padding: 8px 20px;
    background-color: transparent;
    border: none;
    color: #6B7280; 
    font-size: 14px;
    font-weight: 600;
    margin: 2px 15px; 
    border-radius: 8px;
    min-height: 34px; 
}

#sidebarWidget QPushButton:hover {
    background-color: #F0F7FF; 
    color: #1558A8;            
}

QPushButton#dashboardButton {
    background-color: #F0F7FF !important;
    color: #1558A8 !important;
    font-weight: 900 !important;
    border-left: 4px solid #1558A8 !important;
    border-radius: 0px 8px 8px 0px !important;
}


#dailyIntakeCard, #activeEnergyCard, #stepCountCard, 
#activityLogCard, #sleepQualityCard, #heartRateCard, #systemStatusCard {
    background-color: #FFFFFF;
    border-radius: 12px;
    border: 1px solid #E5E9F2;
}

QLabel#executiveDashboardLabel {
    color: #1558A8;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
}

#headerWidget QPushButton {
    background-color: transparent;
    border: none;
    color: #8C98A4;
    font-size: 14px;
    font-weight: bold;
    padding: 5px 10px;
}

#headerWidget QPushButton:hover {
    color: #1558A8;
}

#navOverviewButton {
    color: #1558A8 !important;
    border-bottom: 3px solid #1558A8;
    border-radius: 0px;
}

#searchLineEdit {
    background-color: #FFFFFF;
    color: #333333;
    border: 1px solid #EAEAEA;
    border-radius: 18px;
    padding: 8px 15px;
    font-size: 13px;
    min-width: 200px;
}


QLabel {
    font-family: 'Segoe UI', 'Roboto', sans-serif;
}

#dailyIntakeCard QLabel, #activeEnergyCard QLabel, #stepCountCard QLabel, 
#sleepQualityCard QLabel, #heartRateCard QLabel, #systemStatusCard QLabel {
    font-size: 11px;
    font-weight: bold;
    color: #8C98A4; 
    text-transform: uppercase;
    letter-spacing: 1px;
}

QLabel#dailyIntakeTitleLabel {
    background-color: #E8F0FE !important;
    color: #1558A8 !important;
    padding: 4px 8px;
    border-radius: 4px;
    border: 1px solid transparent;
}

QLabel#caloriesTextLabel { 
    color: #1558A8 !important; 
    font-size: 56px !important;
    font-weight: 900 !important; 
}

QLabel#heartRateValueLabel { 
    color: #D32F2F !important;
    font-size: 48px !important; 
    font-weight: 900 !important; 
}

QLabel#activeEnergyValueLabel, QLabel#stepCountValueLabel { 
    color: #222222 !important;
    font-size: 32px !important; 
    font-weight: 900 !important;
}

QLabel#sleepTimeLabel { 
    font-size: 32px !important; 
    color: #222222 !important; 
    font-weight: 900 !important;
}

QProgressBar {
    background-color: #EBF0F5;
    border: none;
    border-radius: 4px;
    color: transparent; 
    max-height: 12px; 
}

#caloriesProgressBar::chunk { background-color: #1558A8; border-radius: 4px; } 
#stepCountProgressBar::chunk { background-color: #1558A8; border-radius: 4px; } 
#sleepProgressBar::chunk { background-color: #6B4BA3; border-radius: 4px; }


QLabel#activityLogTitle {
    color: #222222;
    font-size: 18px;
    font-weight: 900;
}

QLabel#viewAllLabel {
    color: #1558A8;
    font-size: 13px;
    font-weight: bold;
}

QTableWidget#activityTable {
    border: none;
    gridline-color: transparent; 
    background-color: transparent;
    color: #222222;
    font-size: 13px;
    font-weight: 600;
    outline: none; 
}

QHeaderView::section {
    background-color: transparent;
    color: #8C98A4;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: none;
    border-bottom: 1px solid #EAEAEA; 
    padding: 10px 5px 10px 10px; /* FIXED: Left padding added */
    text-align: left;
}

QTableWidget#activityTable::item {
    border-bottom: 1px solid #F4F7FA; 
    border-top: none;
    border-left: none;
    border-right: none;
    padding: 6px 5px 6px 10px; /* FIXED: Left padding added */
}

QTableWidget#activityTable::item:selected {
    background-color: transparent;
    color: #222222;
}

/* Colorful Status Pills - UPDATED WITH BORDER FIX */
QLabel#hydrationStatusLabel {
    background-color: #E8F5E9 !important; 
    color: #2E7D32 !important;            
    border-radius: 4px;
    padding: 4px 8px;
    font-weight: bold;
    border: 1px solid transparent;
}

QLabel#recoveryStatusLabel {
    background-color: #E3F2FD !important; 
    color: #1565C0 !important;            
    border-radius: 4px;
    padding: 4px 8px;
    font-weight: bold;
    border: 1px solid transparent;
}

QLabel#stressStatusLabel {
    background-color: #FFF3E0 !important; 
    color: #E65100 !important;            
    border-radius: 4px;
    padding: 4px 8px;
}</string>
