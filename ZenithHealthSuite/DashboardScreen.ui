  <property name="styleSheet">
   <string notr="true">
#centralwidget {
    background-color: #F4F7F9;
}

#sidebarWidget {
    background-color: #FFFFFF;
    border-right: 1px solid #E0E0E0;
}

#headerWidget {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E0E0E0;
}

#dailyIntakeCard, #activeEnergyCard, #stepCountCard, 
#activityLogCard, #sleepQualityCard, #heartRateCard, #systemStatusCard {
    background-color: #FFFFFF;
    border-radius: 15px;
    border: 1px solid #EAEAEA;
}


QProgressBar {
    background-color: #EBF0F5;
    border: none;
    border-radius: 8px;
    color: transparent; 
    max-height: 16px;   
}


#caloriesProgressBar::chunk {
    background-color: #FF8C00;
    border-radius: 8px;
}


#stepCountProgressBar::chunk {
    background-color: #007BFF;
    border-radius: 8px;
}


#sleepProgressBar::chunk {
    background-color: #28A745;
    border-radius: 8px;
}


QPushButton {
    background-color: #F8F9FA;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    padding: 8px 15px;
    color: #333333;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #E9ECEF;
    border-color: #007BFF;
}

#sidebarWidget QPushButton {
    text-align: left;
    padding-left: 20px; 
    background-color: transparent;
    border: none;
}

#sidebarWidget QPushButton:hover {
    background-color: #F0F7FF;
    color: #007BFF;
}


#syncDataButton {
    background-color: #007BFF; 
    color: #FFFFFF;            
    font-weight: bold;
    border-radius: 8px;
}

#syncDataButton:hover {
    background-color: #0056B3;
}


QLabel {
    font-family: 'Segoe UI', sans-serif;
    color: #2C3E50;
}

#dailyIntakeCard QLabel, #activeEnergyCard QLabel, #stepCountCard QLabel, 
#sleepQualityCard QLabel, #heartRateCard QLabel, #systemStatusCard QLabel {
    font-size: 11px;
    font-weight: bold;
    color: #7F8C8D;
    text-transform: uppercase;
}


#caloriesTextLabel, #activeEnergyValueLabel, #stepCountValueLabel, 
#sleepTimeLabel, #heartRateValueLabel {
    font-size: 22px;
    font-weight: bold;
    color: #2C3E50;
}

#sidebarWidget QPushButton {
    font-size: 14px;
    font-weight: 500;
}

#searchLineEdit {
    background-color: #F1F3F4;
    color: #333333;
    border: 1px solid #F1F3F4;
    border-radius: 20px; 
    padding: 8px 15px;
    font-size: 13px;
}

#searchLineEdit:focus {
    background-color: #FFFFFF;
    border: 1px solid #007BFF; 
}


#headerWidget QLabel {
    font-size: 18px;
    font-weight: bold;
    color: #1A73E8; 
}

QTableWidget {
    border: none;
    background-color: transparent;
}
QTableWidget {
    border: none;
    gridline-color: #F4F7F9; 
    background-color: transparent;
}


QLabel {
    font-family: 'Segoe UI', 'Roboto', 'Arial', sans-serif;
    color: #2C3E50;
}


#dailyIntakeCard QLabel, #activeEnergyCard QLabel, #stepCountCard QLabel,
#sleepQualityCard QLabel, #heartRateCard QLabel, #systemStatusCard QLabel {
    font-size: 12px;
    font-weight: bold;
    color: #7F8C8D;
    text-transform: uppercase;
    text-align: left;
}


#caloriesTextLabel, #activeEnergyValueLabel, #stepCountValueLabel,
#sleepTimeLabel, #heartRateValueLabel {
    font-size: 24px;
    font-weight: bold;
    color: #2C3E50;
}


QTableWidget {
    border: none;
    gridline-color: transparent;
    background-color: transparent;
}

#sidebarWidget QPushButton {
    text-align: left;
    background-color: transparent;
    border: none;
    margin-right: 15px; 
}</string>
