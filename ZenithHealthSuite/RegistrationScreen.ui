     <property name="styleSheet">
      <string notr="true">
QLineEdit {
    background-color: #FFFFFF; /* Pure white background */
    border: 1px solid #DEDEDE; /* Subtle light gray border */
    border-radius: 4px;        /* Soft, modern rounded corners */
    padding: 8px;              /* Space inside the field for the text */
    color: #333333;
}

/* Apply the same style to the Medical History text area and Gender dropdown */
QTextEdit, QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #DEDEDE;
    border-radius: 4px;
    padding: 8px;
    color: #333333;
}

/* Standardizing the look for labels inside text fields */
QLineEdit[text=&quot;&quot;], QTextEdit[text=&quot;&quot;], QComboBox[text=&quot;&quot;] {
    color: #A0A0A0; /* Light gray for placeholder/empty text */
}</string>
