  <property name="styleSheet">
   <string notr="true">#centralWidget {
    background-color: #E9ECEF; 
}
QLabel#mainTitle {
    color: #4A4A4A;     
    font-size: 20px;    
    font-weight: bold;
    background-color: transparent; 
}

QLabel#subTitle {
    color: #777777;     
    font-size: 14px;
    font-weight: normal;
    background-color: transparent;
}
QFrame#card1, QFrame#card2, QFrame#card3 {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 8px; 
}

QLabel {
    color: #888888; 
    font-size: 11px;
    font-weight: bold;
    background-color: transparent;
}

QLabel#sectionNum1, QLabel#sectionNum2, QLabel#sectionNum3 {
    color: #004696;
}


QLabel#sectionTitle1, QLabel#sectionTitle2, QLabel#sectionTitle3 {
    color: #111111;
    font-size: 24px;
    font-weight: bold;
    text-transform: none; /* Keeps it normal case, not ALL CAPS */
}


QLineEdit, QComboBox, QDateEdit {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid #CCCCCC; 
    padding-bottom: 8px;
    font-size: 14px;
    color: #333333;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border-bottom: 2px solid #004696;
}

QDateEdit::drop-down {
    border: none;
}
QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #333333;            
    border: 1px solid #CCCCCC;
    selection-background-color: #004696; 
    selection-color: #FFFFFF;  
}

QTextEdit {
    background-color: #FFFFFF;
    border: 1px solid #CCCCCC;
    color: #333333;
    font-size: 14px;
}
QPlainTextEdit {
    background-color: transparent;
    border: 1px solid #CCCCCC; 
    border-radius: 4px;        
    padding: 10px;             
    color: #333333;           
    font-size: 15px;         
}

QPlainTextEdit:focus {
    border: 2px solid #004696; 
    background-color: #F8FBFF; 
}

QCheckBox {
    color: #666666;      
    font-size: 13px;   
    spacing: 10px;     
    background-color: transparent;
}
QLabel#consentText {
    color: #666666;
    font-size: 13px;
    font-weight: normal;
    text-transform: none;
}

QPushButton#completeRegistrationButton {
    background-color: #004696;
    color: white;
    font-size: 14px;
    font-weight: bold;
    border: none;
    border-radius: 4px; 
    padding: 12px;      
}


QPushButton#completeRegistrationButton:hover {
    background-color: #002D62; 
    cursor: pointer;
}</string>
