  <property name="styleSheet">
   <string notr="true">#headerWidget {
    background-color: transparent;
    border-bottom: none;
}

QLabel#lblHeaderTitle {
    color: #1558A8;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
}

#headerWidget QPushButton {
    background-color: transparent;
    border: none;
    color: #8C98A4;
    font-size: 14px;
    font-weight: bold;
    padding: 5px 10px;
}

#headerWidget QPushButton:hover {
    color: #1558A8;
}

#navOverviewButton {
    color: #1558A8 !important;
    border-bottom: 3px solid #1558A8;
    border-radius: 0px;
}

QLabel {
    font-family: 'Segoe UI', 'Roboto', sans-serif;
}

#sidebarWidget {
    background-color: #FFFFFF;
    border-right: 1px solid #E5E7EB;
    min-width: 260px; 
}

#appNameLabel {
    color: #1558A8;
    font-size: 18px;
    font-weight: 800;
    padding: 5px 15px 0px 15px;
    background-color: transparent;
    margin-top: 0px;
    border: none;
    min-height: 30px;
    max-height: 35px;
}

#sidebarWidget QPushButton {
    text-align: left;
    padding: 8px 20px;
    background-color: transparent;
    border: none;
    color: #6B7280; 
    font-size: 14px;
    font-weight: 600;
    margin: 2px 15px; 
    border-radius: 8px;
    min-height: 34px; 
}

#sidebarWidget QPushButton:hover {
    background-color: #F0F7FF; 
    color: #1558A8;            
}

QPushButton#historyButton {
    background-color: #F0F7FF !important;
    color: #1558A8 !important;
    font-weight: 900 !important;
    border-left: 4px solid #1558A8 !important;
    border-radius: 0px 8px 8px 0px !important;
}

/* =========================================
   1. MAIN CONTAINERS
========================================= */
QFrame#topCardsFrame {
    background: transparent !important;
    border: none !important;
}

QFrame#tableHeaderFrame, QFrame#paginationFrame {
    background-color: #FFFFFF !important;
    border-radius: 12px !important;
    border: 1px solid #E2E8F0 !important;
}

QFrame#cardTotalWorkouts, QFrame#cardActiveHours, QFrame#cardAvgHeartRate, QFrame#cardConsistency {
    background-color: #FFFFFF !important;
    border-radius: 12px !important;
    border: 1px solid #E2E8F0 !important;
}

/* =========================================
   2. TOP CARDS TEXT (Boldness Kam Ki Hai)
========================================= */
QLabel#lblTotalWorkoutsTitle, QLabel#lblActiveHoursTitle, QLabel#lblAvgHeartRateTitle, QLabel#lblConsistencyTitle {
    color: #64748B !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: 600 !important;
    font-size: 11px !important;
    letter-spacing: 1px !important;
    border: none !important;
    background: transparent !important;
}

/* Yahan Boldness 900 se kam kar ke sirf 'bold' kar di hai */
QLabel#lblTotalWorkoutsValue, QLabel#lblActiveHoursValue, QLabel#lblAvgHeartRateValue, QLabel#lblConsistencyValue {
    color: #0F172A !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important; 
    font-size: 28px !important; 
    border: none !important;
    background: transparent !important;
}

/* =========================================
   3. TABLE TITLES (Boldness Kam Ki Hai)
========================================= */
QLabel#lblTableTitle {
    color: #0F172A !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important; /* 900 khatam kar diya */
    font-size: 20px !important;
    border: none !important;
    background: transparent !important;
}

QLabel#lblTableSubtitle {
    color: #64748B !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-size: 13px !important;
    border: none !important;
    background: transparent !important;
}

/* =========================================
   4. PROFESSIONAL BUTTONS (Zabardasti lagayi hai)
========================================= */
QComboBox#comboFilter {
    background-color: #F8FAFC !important;
    border: 1px solid #E2E8F0 !important;
    border-radius: 6px !important;
    padding: 6px 12px !important;
    color: #0F172A !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important;
    font-size: 13px !important;
}

QComboBox#comboFilter::drop-down {
    border: none !important;
    width: 0px !important;
}

QComboBox#comboFilter::down-arrow {
    image: none !important;
}

QPushButton#btnExport {
    background-color: #FFFFFF !important;
    border: 1px solid #000000 !important; /* Black Outline as per your code */
    border-radius: 6px !important;
    padding: 6px 16px !important;
    color: #000000 !important; /* Black Text as per your code */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important;
    font-size: 13px !important;
}

QPushButton#btnExport:hover {
    background-color: #000000 !important;
    color: #FFFFFF !important; /* Hover par text white ho jaye */
}

/* =========================================
   5. THE MAIN TABLE
========================================= */
QTableWidget {
    background-color: #FFFFFF !important;
    border: 1px solid #E2E8F0 !important;
    border-radius: 10px !important;
    gridline-color: transparent !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-size: 13px !important;
    color: #475569 !important;
}

QHeaderView::section {
    background-color: #FFFFFF !important;
    color: #8C98A4 !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important;
    font-size: 11px !important;
    padding: 16px !important;
    border: none !important;
    border-bottom: 2px solid #F1F5F9 !important;
    text-align: left !important;
}

QTableWidget::item {
    padding: 12px 10px !important;
    border-bottom: 1px solid #F1F5F9 !important;
}

/* =========================================
   6. PAGINATION BUTTONS (Fixing '1')
========================================= */
QPushButton#btnPrevPage, QPushButton#btnNextPage, QPushButton#btnPage2, QPushButton#btnPage3 {
    background-color: #FFFFFF !important;
    border: 1px solid #E2E8F0 !important;
    border-radius: 6px !important;
    color: #475569 !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-weight: bold !important;
    font-size: 13px !important;
    min-width: 32px !important;
    min-height: 32px !important;
}


QLabel#lblShowingRecords {
    color: #64748B !important;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif !important;
    font-size: 13px !important;
    background: transparent !important;
    border: none !important;
}</string>
