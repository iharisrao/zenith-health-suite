    <property name="styleSheet">
     <string notr="true">QFrame#background {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #0a1128, stop:1 #01040f);
}

QFrame#mainCard {
    background-color: #ffffff;
    border-radius: 15px; 
}

QLabel#welcomeLabel {
    color: #6c757d; 
    font-size: 14px; 
    font-weight: normal;
}

QFrame#loginbox {
    background-color: transparent;
    border: none;
}

QLabel {
    color: #4a5568; 
    font-weight: bold;
    font-size: 11px;
    background: transparent;
}

QLabel#imageLabel {
    background: transparent;
    color: transparent;
}

QLabel#titleLabel {
    color: #1a56c0; 
    font-size: 28px; 
    font-weight: 900; 
}

QLineEdit#usernameLineEdit, QLineEdit#passwordLineEdit {
    background-color: #e8ecef;
    border: none; 
    border-radius: 10px; 
    color: #1a1a1a;
    font-size: 13px;
    background-repeat: no-repeat;
    background-position: 12px center; 
    padding-left: 50px; 
    padding-top: 10px;
    padding-bottom: 10px;
}

QLineEdit#usernameLineEdit {
	background-image: url(:/icons/account.png);
}

QLineEdit#passwordLineEdit {
	background-image: url(:/icons/lock.png);
}

QPushButton#signInButton {
    background: #1a56c0;
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: bold;
    font-size: 14px;
    padding: 12px;
}

QPushButton#signInButton:hover {
    background: #134296; 
}

QPushButton#signUpButton {
    background: transparent;
    color: #1a56c0;
    border: 2px solid #1a56c0;
    border-radius: 10px;
    font-weight: bold;
    font-size: 14px;
    padding: 10px;
}

QPushButton#signUpButton:hover {
    background: rgba(26, 86, 192, 0.05); 
}

QLabel#securitylabel {
    color: #6c757d;
    font-size: 11px;
    font-weight: normal;
}</string>
